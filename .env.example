# ============================================
# Deep Research Agent - Environment Variables
# ============================================

# --- LLM Configuration ---
LLM_PROVIDER=openai
LLM_MODEL=gpt-4o-mini
LLM_API_KEY=your_llm_api_key_here
LLM_BASE_URL=
LLM_MAX_TOKENS=16384
LLM_TEMPERATURE=0.3
# 生产：进程级全局 LLM 并发闸门（实测 mimo 后端安全上限）
LLM_MAX_CONCURRENCY=12
# 生产：各节点内子问题并发数
ANALYST_CONCURRENCY=8
FACT_CHECKER_CONCURRENCY=5
# Benchmark 专用总 LLM 预算（pipeline + RAGAS 共享，比生产略保守）
LLM_BENCHMARK_CONCURRENCY=10

# --- Search Configuration ---
# USE_TAVILY=true → Tavily（推荐），false → DuckDuckGo（免费，无需 key）
USE_TAVILY=true
TAVILY_API_KEY=your_tavily_key_here
SERPER_API_KEY=your_serper_key_here
BING_API_KEY=your_bing_key_here
MAX_SEARCH_RESULTS=5

# --- Qdrant (默认使用内存模式，无需配置) ---
# QDRANT_URL=http://localhost:6333
# QDRANT_API_KEY=
QDRANT_COLLECTION=deep_research_chunks

# --- RAG Configuration ---
# EMBEDDING_PROVIDER=fastembed  → 本地 fastembed 模型（默认）
# EMBEDDING_PROVIDER=api        → 通过 LiteLLM 调用 API（复用 LLM_API_KEY）
EMBEDDING_PROVIDER=fastembed
EMBEDDING_MODEL=BAAI/bge-small-en-v1.5
EMBEDDING_DIM=384
# 切换 API 模式示例（text-embedding-3-small，需 OpenAI key）:
# EMBEDDING_PROVIDER=api
# EMBEDDING_MODEL=text-embedding-3-small
# EMBEDDING_DIM=1536
CHUNK_SIZE=800
CHUNK_OVERLAP=200
RAG_TOP_K=6

# --- App Configuration ---
APP_ENV=development
LOG_LEVEL=INFO
MAX_ROUNDS=2
REQUEST_TIMEOUT=30
MAX_CONCURRENT_FETCHES=5
MAX_SOURCES_PER_ROUND=20

# --- Secret ---
SECRET_KEY=your-secret-key-change-in-production

# --- GitHub ---
GITHUB_TOKEN=your_github_pat_here
