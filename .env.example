# ============================================
# Deep Research Agent - Environment Variables
# ============================================

# --- LLM Configuration ---
LLM_PROVIDER=openai
LLM_MODEL=gpt-4o-mini
LLM_API_KEY=your_llm_api_key_here
LLM_BASE_URL=
LLM_MAX_TOKENS=16384
LLM_TEMPERATURE=0.3

# --- Search Configuration ---
# Options: tavily, serper, bing, duckduckgo
SEARCH_PROVIDER=duckduckgo
TAVILY_API_KEY=your_tavily_key_here
SERPER_API_KEY=your_serper_key_here
BING_API_KEY=your_bing_key_here
MAX_SEARCH_RESULTS=5

# --- Qdrant (默认使用内存模式，无需配置) ---
# QDRANT_URL=http://localhost:6333
# QDRANT_API_KEY=
QDRANT_COLLECTION=deep_research_chunks

# --- RAG Configuration ---
EMBEDDING_MODEL=BAAI/bge-small-en-v1.5
EMBEDDING_DIM=384
CHUNK_SIZE=800
CHUNK_OVERLAP=120
RAG_TOP_K=6

# --- App Configuration ---
APP_ENV=development
LOG_LEVEL=INFO
MAX_ROUNDS=2
REQUEST_TIMEOUT=30
MAX_CONCURRENT_FETCHES=5
MAX_SOURCES_PER_ROUND=20

# --- Secret ---
SECRET_KEY=your-secret-key-change-in-production
